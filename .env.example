# Google APIs (YouTube Data API v3 + Gemini, 같은 키 사용 가능)
GOOGLE_API_KEY=

# Gemini 전용 키를 분리하려면 (선택)
# GEMINI_API_KEY=
# YOUTUBE_API_KEY=

# Dropbox
DROPBOX_ACCESS_TOKEN=
# Vault 루트 경로 (이 아래에 카테고리/검색어 폴더가 자동 생성됨)
# App folder 사용 시 예: /Apps/youtube-obsidian-sync/YouTube
# Full Dropbox 사용 시 예: /Obsidian/Vault/YouTube
DROPBOX_VAULT_PATH=/Apps/youtube-obsidian-sync/YouTube

# Gemini 모델 설정
GEMINI_MODEL=gemini-2.0-flash-exp

# 처리 제한
MAX_VIDEOS_PER_BATCH=10
MAX_RESULTS_PER_SEARCH=25
