# ─── YouTube Data API v3 (Google Cloud Console에서 발급) ───
YOUTUBE_API_KEY=

# ─── Gemini API (Google AI Studio 또는 Google Cloud Console에서 발급) ───
# 계획서 초안에는 한 키로 묶을 수 있다고 적었지만 실제로는 별도 키가 필요하다.
GEMINI_API_KEY=

# Gemini 모델 (기본값: gemini-flash-latest)
GEMINI_MODEL=gemini-flash-latest

# ─── Dropbox (refresh_token 기반 자동 갱신) ───
# DROPBOX_ACCESS_TOKEN은 더 이상 사용하지 않는다. 2021-09 이후 Dropbox 신규 앱의 access_token은
# 단기(약 4시간)만 발급되므로, scripts/dropbox-exchange-code.mjs를 1회 실행해 long-lived
# refresh_token을 발급받고 아래 3개 변수를 채워 둔다. 호출 직전마다 lib/dropbox/auth.ts가 새
# access_token을 받아 메모리 캐시한다 (만료 5분 전 사전 갱신).
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# Vault 루트 경로 (이 아래에 카테고리/검색어 폴더가 자동 생성됨)
# App folder 사용 시 예: /Apps/youtube-obsidian-sync/YouTube
# Full Dropbox 사용 시 예: /Obsidian/Vault/YouTube
DROPBOX_VAULT_PATH=/Apps/youtube-obsidian-sync/YouTube

# ─── 처리 제한 ───
# 한 번에 일괄 처리 가능한 최대 영상 수. Vercel Hobby 플랜의 60초 함수 타임아웃을 감안하면
# 2~3 정도로 낮추는 것이 안전 (영상당 ~15~40초). Pro 플랜(300초)이면 10까지 안정.
MAX_VIDEOS_PER_BATCH=10

# 검색 결과 한 페이지당 영상 수. YouTube Data API의 maxResults에 그대로 전달 (1~50 클램프).
MAX_RESULTS_PER_SEARCH=20
